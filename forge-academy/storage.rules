rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return signedIn() && userDoc().role in ['academy_admin', 'super_admin', 'creator'];
    }

    function ownsStudent(studentId) {
      return signedIn()
        && userDoc().role == 'student'
        && userDoc().studentId == studentId;
    }

    function isProfileImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp|gif)');
    }

    match /student-profiles/{studentId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if (isAdmin() || ownsStudent(studentId)) && isProfileImage();
      allow delete: if isAdmin() || ownsStudent(studentId);
    }

    function isDashboardMedia() {
      return request.resource.size < 100 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('application/vnd.*')
        );
    }

    match /digital-dashboard-media/{mediaId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if isAdmin() && isDashboardMedia();
      allow delete: if isAdmin();
    }

    function isCertificateTemplateImage() {
      return request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    match /certificate-templates/{templateId}/{fileName} {
      allow read: if true;
      allow create, update: if isAdmin() && isCertificateTemplateImage();
      allow delete: if isAdmin();
    }
  }
}
